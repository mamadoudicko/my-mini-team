#!/usr/bin/env node
'use strict';
const readline = require('readline');
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');
const { C, SYM, startSpinner } = require('../lib/ui');
const store = require('../lib/store');
const { shapeLine, workflowBlock } = require('../lib/render');
const runner = require('../lib/runner');
const compose = require('../lib/compose');
const portable = require('../lib/portable');
const skills = require('../lib/skills');
const agents = require('../lib/agents');
const yaml = require('../lib/yaml');
const { normalizeTeam, teamSkills } = require('../lib/model');
const lineup = require('../lib/lineup');
const bundle = require('../lib/bundle');

process.stdout.on('error', (e) => { if (e.code === 'EPIPE') process.exit(0); });

function spawnEditor(file) {
  const editor = process.env.VISUAL || process.env.EDITOR || (process.platform === 'win32' ? 'notepad' : 'vi');
  spawnSync(editor, [file], { stdio: 'inherit' });
}

function home() {
  const teams = store.loadAll();
  console.log('\n  ' + C.bold('my mini teams') + '\n');
  if (!teams.length) {
    console.log('  ' + C.dim('no teams yet. create one:') + '  ' + C.cyan('mmt new') + '\n');
    return;
  }
  for (const t of teams) {
    if (t.error) { console.log('  ' + C.red(t.name) + C.dim('  ' + t.error)); continue; }
    const tag = C.dim('[' + t.scope + ']');
    const shadowed = store.filesOf(t.name).length > 1 ? C.yellow('  · shadows a global copy') : '';
    console.log('  ' + C.cyan(t.name.padEnd(16)) + ' ' + tag.padEnd(9) + ' ' + shapeLine(t.team) + shadowed);
  }
  console.log('\n  ' + C.dim('run:') + '  ' + C.cyan('mmt run <team> "your task"') +
    '   ' + C.dim('· see:') + ' ' + C.cyan('mmt show team <name>') +
    '   ' + C.dim('· build:') + ' ' + C.cyan('mmt new team <name>') + '\n');
}

function show(name) {
  if (!name) {
    console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt show team <name>'));
    return home();
  }
  const team = store.loadTeam(name);
  if (!team) return notFound(name);
  const resolved = lineup.effectiveSteps(team);
  console.log('');
  workflowBlock(resolved).forEach((l) => console.log(l));
  console.log('\n  ' + C.dim('shape:') + '  ' + shapeLine(resolved));
  const missing = teamSkills(team).filter((n) => !skills.resolve(n));
  if (missing.length) {
    console.log('  ' + C.yellow('unknown skills: ') + missing.join(', ') + C.dim('  (define: mmt new skill <name>)'));
  }
  const unknownAgents = lineup.unresolvedAgents(team);
  if (unknownAgents.length) console.log('  ' + C.yellow('unknown agents: ') + unknownAgents.join(', ') + C.dim('  (create: mmt new agent <name>)'));
  console.log('');
}

// Auto-launch an interactive Claude Code session (subscription) that runs the
// /mmt command. Passing the whole command as ONE argv element avoids all shell
// quoting issues (# and nested quotes).
function pointer(argsStr) {
  const seed = '/mmt ' + argsStr;
  console.log('\n  ' + C.dim('Opening a Claude Code session on your subscription…'));
  console.log('  ' + C.dim('running: ') + C.cyan(seed) + '\n');
  const r = spawnSync('claude', [seed], { stdio: 'inherit' });
  if (r && r.error) {
    console.log('\n  ' + C.red('`claude` not found on PATH.') + C.dim(' Open Claude Code yourself and run:'));
    console.log('    ' + C.cyan(seed) + '\n');
  }
}

async function run(name, task, opts) {
  const team = store.loadTeam(name);
  if (!team) return notFound(name);
  if (opts.sim) return runner.run(team, task, { sim: true, fast: opts.fast });
  if (opts.headless) {
    console.log('  ' + C.yellow('⚠ --headless uses claude -p → Agent SDK credit / API, NOT your subscription.'));
    return runner.run(team, task, { model: opts.model });
  }
  if (!task) return pointer('run ' + name + (opts.model ? ' --model ' + opts.model : ''));
  pointer('run ' + name + ' "' + task + '"' + (opts.model ? ' --model ' + opts.model : ''));
}

function notFound(name) {
  console.log('\n  ' + C.red(`no team "${name}"`) + '  ' + C.dim('· see your teams:') + ' ' + C.cyan('mmt list teams') + '\n');
}

function skillsList() {
  const list = skills.list();
  console.log('\n  ' + C.bold('skills') + C.dim('  — reusable capabilities you can plug into a member') + '\n');
  if (!list.length) {
    console.log('  ' + C.dim('none yet. create one:') + '  ' + C.cyan('mmt new skill <name>') + '\n');
    return;
  }
  for (const s of list) {
    console.log('  ' + C.blue(s.name.padEnd(18)) + ' ' + C.dim('[' + s.source + ']').padEnd(11) + ' ' + C.dim(s.description || ''));
  }
  console.log('\n  ' + C.dim('edit:') + ' ' + C.cyan('mmt edit skill <name>') + '   ' + C.dim('new:') + ' ' + C.cyan('mmt new skill <name>') + '\n');
}

// Resolve save scope: --local / --global win; otherwise ask (TTY) or default
// to global. Returns { local }. Global = ~/.claude, local = ./.claude.
async function chooseScope(opts = {}) {
  if (opts.local) return { local: true };
  if (opts.global) return { local: false };
  if (!process.stdin.isTTY) return { local: false };
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const ans = (await ask(rl, C.cyan('  save where?') + C.dim(' [g]lobal ~/.claude/skills · [l]ocal ./.claude/skills') + ' (G/l): ')).toLowerCase();
  rl.close();
  return { local: ans === 'l' || ans === 'local' };
}

async function skillCmd(sub, name, opts = {}) {
  if (!sub || sub === 'ls' || sub === 'list') return skillsList();
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan(`mmt ${sub} skill <name>`) + '\n'); return; }

  if (sub === 'show') {
    const s = skills.resolve(name);
    if (!s) return skillMissing(name);
    console.log('\n  ' + C.blue(name) + C.dim('  [' + s.source + ']  ' + s.file) + '\n\n' + s.content + '\n');
  } else if (sub === 'edit') {
    const s = skills.resolve(name);
    if (!s) { console.log('\n  ' + C.yellow(`no skill "${name}"`) + C.dim('  · create it: ') + C.cyan('mmt new skill ' + name) + '\n'); return; }
    if (opts.ui || opts.file) {   // --ui: edit it yourself in $EDITOR
      spawnEditor(s.file);
      console.log('\n  ' + C.green('✔ edited ') + C.blue(name) + C.dim('  (' + s.file + ')') + '\n');
      return;
    }
    // bare: describe the change, Claude rewrites it (Anthropic skill standard)
    const instruction = (opts.prompt || opts.desc || '').trim() || await promptLine(C.cyan(`  what should change about "${name}"? `));
    if (!instruction) { console.log('\n  ' + C.dim('nothing to change.') + '\n'); return; }
    let content;
    try { const stop = startSpinner('updating the skill…'); content = await compose.editSkill(s.content, instruction, name); stop(); }
    catch (e) { return composeError(e); }
    fs.writeFileSync(s.file, content);
    console.log('\n  ' + C.green('✔ updated ') + C.blue(name) + C.dim('  (' + s.file + ')') + '\n');
  } else if (sub === 'new') {
    const existing = skills.resolve(name);
    if (existing) { console.log('\n  ' + C.dim(`"${name}" exists [${existing.source}] — opening it`) + '\n'); spawnEditor(existing.file); return; }
    const scope = await chooseScope(opts);
    if (opts.ui || opts.file) {   // --ui: open a template in $EDITOR
      const template = `---\nname: ${name}\ndescription: \n---\n\n# ${name}\n\nWhat this skill does. In the description above, say "Use when …" so Claude discovers it.\n`;
      const file = skills.writeSkill(name, template, scope);
      spawnEditor(file);
      console.log('\n  ' + C.green('✔ created ') + C.blue(name) + C.dim('  [' + (scope.local ? 'project' : 'user') + ']  (' + file + ')') + '\n');
      return;
    }
    // bare: describe it, Claude writes it (Anthropic skill standard)
    const description = (opts.prompt || opts.desc || '').trim() || await promptLine(C.cyan(`  what should "${name}" do? `));
    if (!description) { console.log('\n  ' + C.dim('nothing to create.') + '\n'); return; }
    let content;
    try { const stop = startSpinner('writing the skill…'); content = await compose.composeSkill(name, description); stop(); }
    catch (e) { return composeError(e); }
    const file = skills.writeSkill(name, content, scope);
    console.log('\n  ' + C.green('✔ created ') + C.blue(name) + C.dim('  [' + (scope.local ? 'project' : 'user') + ']  (' + file + ')'));
    console.log('  ' + C.dim('review/refine:') + ' ' + C.cyan('mmt edit skill ' + name + ' --ui') + '\n');
  } else {
    console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt show|edit|new skill <name>') + '  ' + C.dim('· or ') + C.cyan('mmt list skills') + '\n');
  }
}

function skillMissing(name) {
  console.log('\n  ' + C.yellow(`no skill "${name}"`) + '  ' + C.dim('· list them:') + ' ' + C.cyan('mmt skills') + '\n');
}

function agentsList() {
  const list = agents.list();
  console.log('\n  ' + C.bold('agents') + C.dim('  — native subagents Claude can delegate to') + '\n');
  if (!list.length) {
    console.log('  ' + C.dim('none yet. create one:') + '  ' + C.cyan('mmt new agent <name>') + '\n');
    return;
  }
  for (const a of list) {
    const model = a.model ? C.dim('  (' + a.model + ')') : '';
    console.log('  ' + C.blue(a.name.padEnd(18)) + ' ' + C.dim('[' + a.source + ']').padEnd(11) + ' ' + C.dim(a.description || '') + model);
  }
  console.log('\n  ' + C.dim('edit:') + ' ' + C.cyan('mmt edit agent <name>') + '   ' + C.dim('new:') + ' ' + C.cyan('mmt new agent <name>') + '\n');
}

function agentMissing(name) {
  console.log('\n  ' + C.yellow(`no agent "${name}"`) + '  ' + C.dim('· list them:') + ' ' + C.cyan('mmt agents') + '\n');
}

async function agentCmd(sub, name, opts = {}) {
  if (!sub || sub === 'ls' || sub === 'list') return agentsList();
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan(`mmt ${sub} agent <name>`) + '\n'); return; }

  if (sub === 'show') {
    const a = agents.resolve(name);
    if (!a) return agentMissing(name);
    console.log('\n  ' + C.blue(name) + C.dim('  [' + a.source + ']  ' + a.file) + '\n\n' + a.content + '\n');
  } else if (sub === 'edit') {   // bare = Claude rewrite; --ui (Ink editor) is routed at dispatch
    const a = agents.resolve(name);
    if (!a) { console.log('\n  ' + C.yellow(`no agent "${name}"`) + C.dim('  · create it: ') + C.cyan('mmt new agent ' + name) + '\n'); return; }
    const instruction = (opts.prompt || opts.desc || '').trim() || await promptLine(C.cyan(`  what should change about "${name}"? `));
    if (!instruction) { console.log('\n  ' + C.dim('nothing to change.') + '\n'); return; }
    const skillNames = skills.list().map((s) => s.name);
    let content;
    try { const stop = startSpinner('updating the agent…'); content = await compose.editAgent(a.content, instruction, name, skillNames); stop(); }
    catch (e) { return composeError(e); }
    fs.writeFileSync(a.file, content);
    console.log('\n  ' + C.green('✔ updated ') + C.blue(name) + C.dim('  (' + a.file + ')') + '\n');
  } else if (sub === 'new') {   // bare = Claude draft (auto-selects skills); --ui (Ink editor) at dispatch
    const existing = agents.resolve(name);
    if (existing) { console.log('\n  ' + C.dim(`"${name}" exists [${existing.source}] — opening it`) + '\n'); spawnEditor(existing.file); return; }
    const scope = await chooseScope(opts);
    const role = (opts.prompt || opts.desc || '').trim() || await promptLine(C.cyan(`  what should "${name}" do (its role)? `));
    if (!role) { console.log('\n  ' + C.dim('nothing to create.') + '\n'); return; }
    const skillNames = skills.list().map((s) => s.name);
    let content;
    try { const stop = startSpinner('writing the agent…'); content = await compose.composeAgent(name, role, skillNames); stop(); }
    catch (e) { return composeError(e); }
    const file = agents.writeAgent(name, content, scope);
    console.log('\n  ' + C.green('✔ created ') + C.blue(name) + C.dim('  [' + (scope.local ? 'project' : 'user') + ']  (' + file + ')'));
    console.log('  ' + C.dim('review/refine:') + ' ' + C.cyan('mmt edit agent ' + name + ' --ui') + '\n');
  } else {
    console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt show|edit|new agent <name>') + '  ' + C.dim('· or ') + C.cyan('mmt list agents') + '\n');
  }
}

// `mmt export <team> [dir] [--force]` — a reviewable directory bundle:
// <team>.team.yaml + agents/*.md + skills/<name>/SKILL.md.
function exportCmd(name, dirArg, opts = {}) {
  const team = store.loadTeam(name);
  if (!team) return notFound(name);
  const destDir = path.resolve(dirArg || name);
  const b = bundle.collect(team);
  bundle.writeDir(b, destDir, { force: opts.force });   // throws on existing dir w/o --force; caught by main()
  console.log('');
  bundle.manifest(b).forEach((l) => console.log('  ' + l));
  console.log('\n  ' + C.green('✔ exported ') + C.cyan(name) + C.dim('  → ' + destDir) + '\n');
}

// `mmt import <path> [--yes] [--force] [--local]` — a directory bundle (new)
// or the legacy token/yaml/file/stdin forms (unchanged, minus the sibling-skill
// install target which now goes to native ~/.claude/skills).
async function importCmd(arg, opts = {}) {
  if (arg && fs.existsSync(arg) && fs.statSync(arg).isDirectory()) return importDir(arg, opts);

  let input = arg;
  if (!input && !process.stdin.isTTY) input = fs.readFileSync(0, 'utf8');
  if (!input || !input.trim()) {
    console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan("mmt import '<token>'") + C.dim('   · or ') + C.cyan('mmt import <file|dir>') + C.dim('   · or pipe yaml') + '\n');
    return;
  }
  input = input.trim();
  let yamlText, bundled = [], fromFile = null;
  try {
    if (portable.isToken(input)) { const d = portable.decode(input); yamlText = d.yaml; bundled = d.skills || []; }
    else if (/^team:/m.test(input)) yamlText = input;                 // raw yaml
    else if (fs.existsSync(input)) { yamlText = fs.readFileSync(input, 'utf8'); fromFile = input; } // file
    else throw new Error('unrecognized input — expected a token, a team yaml, or a file/dir path');
  } catch (e) { console.log('\n  ' + C.red(e.message) + '\n'); return; }

  let team;
  try { team = normalizeTeam(yaml.parse(yamlText)); }
  catch (e) { console.log('\n  ' + C.red('invalid team: ' + e.message) + '\n'); return; }

  const installed = [];
  for (const s of bundled) {
    if (s && s.name && s.content && !skills.resolve(s.name)) { skills.writeMmtSkill(s.name, s.content); installed.push(s.name); }
  }

  if (fromFile) {
    for (const name of teamSkills(team)) {
      if (name.includes('/') || name.startsWith('~')) continue;      // path/~ refs
      if (skills.resolve(name)) continue;                            // never overwrite
      const p = path.join(path.dirname(fromFile), 'skills', name, 'SKILL.md');
      if (fs.existsSync(p)) { skills.writeSkill(name, fs.readFileSync(p, 'utf8'), { local: opts.local }); installed.push(name); }
    }
  }

  const file = store.saveTeam(team.team, yamlText, { local: opts.local });
  console.log('');
  workflowBlock(lineup.effectiveSteps(team)).forEach((l) => console.log(l));
  console.log('\n  ' + C.green('✔ imported ') + C.cyan(team.team) + C.dim('  → ' + file));
  if (installed.length) console.log('  ' + C.dim('installed skills: ') + installed.map((n) => C.blue(n)).join(', '));
  console.log('');
}

// `mmt import <dir>` — read a plain-directory bundle, show a manifest + a
// heuristic capability footprint, get explicit consent, then install.
async function importDir(dir, opts = {}) {
  let b;
  try { b = bundle.readDir(dir); }
  catch (e) { console.log('\n  ' + C.red(e.message) + '\n'); process.exitCode = 1; return; }

  console.log('');
  bundle.manifest(b).forEach((l) => console.log('  ' + l));
  console.log('');
  bundle.footprint(b).forEach((l) => console.log('  ' + l));

  if (process.stdin.isTTY) {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    let proceed = false;
    while (!proceed) {
      const ans = (await ask(rl, '\n  ' + C.cyan('install?') + C.dim(' [y]es · [v]iew <name> · [n]o') + ' (Y/n): ')).toLowerCase();
      if (!ans || ans === 'n' || ans === 'no') { rl.close(); console.log('\n  ' + C.dim('nothing installed.') + '\n'); return; }
      if (ans === 'y' || ans === 'yes') { proceed = true; break; }
      const vm = ans.match(/^v(?:iew)?\s+(.+)$/);
      if (vm) {
        const target = vm[1].trim();
        const hit = [...b.agents, ...b.skills].find((x) => x.name === target);
        console.log(hit ? '\n' + hit.content : '\n  ' + C.yellow(`no "${target}" in this bundle`));
        continue;
      }
      console.log('\n  ' + C.dim('y / n / v <name>'));
    }
    rl.close();
  } else if (!opts.yes) {
    console.log('\n  ' + C.dim('non-interactive — re-run with --yes to install without prompting.') + '\n');
    process.exitCode = 1;
    return;
  }

  const file = store.saveTeam(b.team.name, b.team.yamlText, { local: opts.local });
  const lines = [C.dim('team → ' + file)];
  for (const a of b.agents) {
    const target = path.join(agents.agentDir(!!opts.local), a.name + '.md');
    if (fs.existsSync(target) && !opts.force) { lines.push(C.dim('kept agent ') + C.blue(a.name) + C.dim(' (already exists)')); continue; }
    agents.writeAgent(a.name, a.content, { local: opts.local });
    lines.push(C.dim('installed agent ') + C.blue(a.name));
  }
  for (const s of b.skills) {
    const target = path.join(skills.skillDir(!!opts.local), s.name, 'SKILL.md');
    if (fs.existsSync(target) && !opts.force) { lines.push(C.dim('kept skill ') + C.blue(s.name) + C.dim(' (already exists)')); continue; }
    skills.writeSkill(s.name, s.content, { local: opts.local });
    lines.push(C.dim('installed skill ') + C.blue(s.name));
  }
  console.log('\n  ' + C.green('✔ imported ') + C.cyan(b.team.name));
  lines.forEach((l) => console.log('  ' + l));
  console.log('');
}

function delTeam(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt delete team <name>') + '\n'); return; }
  const files = store.deleteTeam(name);
  if (!files.length) return notFound(name);
  console.log('\n  ' + C.green('✔ deleted ') + C.cyan(name) + C.dim('  (' + files.length + ' file' + (files.length > 1 ? 's' : '') + ')'));
  files.forEach((f) => console.log('    ' + C.dim(f)));
  console.log('');
}

function delAgent(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt delete agent <name>') + '\n'); return; }
  const files = agents.deleteAgent(name);
  if (!files.length) return agentMissing(name);
  console.log('\n  ' + C.green('✔ deleted ') + C.blue(name) + C.dim('  (' + files.length + ' file' + (files.length > 1 ? 's' : '') + ')'));
  files.forEach((f) => console.log('    ' + C.dim(f)));
  console.log('');
}

function delSkill(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt delete skill <name>') + '\n'); return; }
  const files = skills.deleteSkill(name);
  if (!files.length) return skillMissing(name);
  console.log('\n  ' + C.green('✔ deleted ') + C.blue(name) + C.dim('  (' + files.length + ' file' + (files.length > 1 ? 's' : '') + ')'));
  files.forEach((f) => console.log('    ' + C.dim(f)));
  console.log('');
}

function ask(rl, q) {
  return new Promise((r) => {
    try { rl.question(q, (a) => r(a.trim())); }
    catch (e) { r(''); } // stdin closed (e.g. piped EOF) -> treat as enter/save
  });
}

// One-shot line prompt (creates + closes its own readline). Empty when non-TTY.
function promptLine(question) {
  return new Promise((resolve) => {
    if (!process.stdin.isTTY) return resolve('');
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    rl.question(question, (a) => { rl.close(); resolve((a || '').trim()); });
  });
}

// Collect multiple lines (so a pasted multi-line description is kept whole).
// Submits on an empty line.
function askMultiline(rl, header) {
  return new Promise((resolve) => {
    process.stdout.write(header);
    const lines = [];
    const onLine = (line) => {
      if (line.trim() === '') { rl.removeListener('line', onLine); resolve(lines.join('\n').trim()); }
      else lines.push(line);
    };
    rl.on('line', onLine);
    rl.once('close', () => { rl.removeListener('line', onLine); resolve(lines.join('\n').trim()); });
  });
}

function preview(yamlText) {
  const team = normalizeTeam(yaml.parse(yamlText));
  const resolved = lineup.effectiveSteps(team);
  console.log('');
  workflowBlock(resolved).forEach((l) => console.log(l));
  console.log('\n  ' + C.dim('shape:') + '  ' + shapeLine(resolved) + '\n');
  return team;
}

// Text-first: describe the workflow in plain words, the agent composes it,
// then refine by talking. No form.
async function newTeam(name, description, opts = {}) {
  if (!opts.headless) return pointer('new ' + name + (description ? ' "' + description + '"' : '') + (opts.local ? ' --local' : ''));
  console.log('\n  ' + C.bold('compose a mini team') + C.dim('  — describe how your team works, in plain words') +
    C.dim(opts.local ? '  [local]' : '  [global]') + '\n');
  let text = (description || '').trim() || (opts.prompt || '').trim();
  if (!text) text = await promptLine(C.cyan(`  describe how "${name}" works: `));
  if (!text) { console.log('\n  ' + C.dim('nothing to compose.') + '\n'); return; }

  let y;
  try {
    const stop = startSpinner('composing your team…');
    y = await compose.compose(text);
    stop();
  } catch (e) { return composeError(e); }
  y = y.replace(/^team:.*$/m, 'team: ' + name);   // the CLI-passed name always wins over the model's guess

  if (!process.stdin.isTTY) {
    const team = preview(y);
    const file = store.saveTeam(team.team, y, { local: opts.local });
    console.log('  ' + C.green('✔ saved ') + C.dim(file) + '\n');
    return;
  }
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  await refine(rl, y, { local: opts.local });
}

// Launch the interactive Ink editor on a team, then save the edited steps back.
async function launchUi(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt edit team <name> --ui') + '\n'); return; }
  const team = store.loadTeam(name);
  if (!team) return notFound(name);
  const file = store.fileOf(name);
  let mod;
  try { mod = await import('../lib/team-editor.mjs'); }
  catch (e) {
    if (e && (e.code === 'ERR_MODULE_NOT_FOUND' || e.code === 'MODULE_NOT_FOUND')) {
      console.log('\n  ' + C.yellow('the visual editor needs its dependencies (ink, react).'));
      console.log('  ' + C.dim('install them: ') + C.cyan('npm install -g @mamadoudicko/mmt') + C.dim('  (or `npm install` in the repo)') + '\n');
    } else {
      console.log('\n  ' + C.red('the visual editor failed to load: ') + e.message + '\n');
    }
    return;
  }
  const steps = await mod.launchEditor(team);
  if (!steps) { console.log('\n  ' + C.dim('closed — no changes saved.') + '\n'); return; }
  const { teamToYaml } = require('../lib/serialize');
  store.saveAt(file, teamToYaml({ ...team, steps }));
  console.log('\n  ' + C.green('✔ saved ') + C.dim(file));
  show(name);
}

// Launch the interactive agent editor (description · model · default skills).
async function launchAgentUi(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt edit agent <name> --ui') + '\n'); return; }
  const agent = agents.resolve(name);
  if (!agent) return agentMissing(name);
  let mod;
  try { mod = await import('../lib/team-editor.mjs'); }
  catch (e) {
    if (e && (e.code === 'ERR_MODULE_NOT_FOUND' || e.code === 'MODULE_NOT_FOUND')) {
      console.log('\n  ' + C.yellow('the visual editor needs its dependencies (ink, react).'));
      console.log('  ' + C.dim('install them: ') + C.cyan('npm install -g @mamadoudicko/mmt') + '\n');
    } else { console.log('\n  ' + C.red('the visual editor failed to load: ') + e.message + '\n'); }
    return;
  }
  const patch = await mod.launchAgentEditor(agent);
  if (!patch) { console.log('\n  ' + C.dim('closed — no changes saved.') + '\n'); return; }
  const { agentToMd } = require('../lib/serialize');
  const md = agentToMd({ name: agent.name, description: patch.description, model: patch.model, skills: patch.skills, body: agent.body });
  fs.writeFileSync(agent.file, md);
  console.log('\n  ' + C.green('✔ saved ') + C.blue(agent.name) + C.dim('  (' + agent.file + ')') + '\n');
}

// Dynamically load the Ink editor module, or print a friendly message + return null.
async function loadUiModule() {
  try { return await import('../lib/team-editor.mjs'); }
  catch (e) {
    if (e && (e.code === 'ERR_MODULE_NOT_FOUND' || e.code === 'MODULE_NOT_FOUND')) {
      console.log('\n  ' + C.yellow('the visual editor needs its dependencies (ink, react).'));
      console.log('  ' + C.dim('install them: ') + C.cyan('npm install -g @mamadoudicko/mmt') + '\n');
    } else { console.log('\n  ' + C.red('the visual editor failed to load: ') + e.message + '\n'); }
    return null;
  }
}

// Create a NEW agent through the Ink editor (blank template → checkboxes).
async function launchAgentUiNew(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt new agent <name> --ui') + '\n'); return; }
  if (agents.resolve(name)) { console.log('\n  ' + C.dim(`"${name}" already exists — edit it: `) + C.cyan('mmt edit agent ' + name + ' --ui') + '\n'); return; }
  const scope = await chooseScope({});
  const mod = await loadUiModule();
  if (!mod) return;
  const patch = await mod.launchAgentEditor({ name, description: '', model: '', skills: [], body: '' });
  if (!patch) { console.log('\n  ' + C.dim('closed — nothing created.') + '\n'); return; }
  const { agentToMd } = require('../lib/serialize');
  const md = agentToMd({ name, description: patch.description, model: patch.model, skills: patch.skills, body: patch.description });
  const file = agents.writeAgent(name, md, scope);
  console.log('\n  ' + C.green('✔ created ') + C.blue(name) + C.dim('  [' + (scope.local ? 'project' : 'user') + ']  (' + file + ')') + '\n');
}

// Create a NEW team through the Ink editor (blank steps → build it up).
async function launchUiNew(name) {
  if (!name) { console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan('mmt new team <name> --ui') + '\n'); return; }
  if (store.loadTeam(name)) { console.log('\n  ' + C.dim(`"${name}" already exists — edit it: `) + C.cyan('mmt edit team ' + name + ' --ui') + '\n'); return; }
  const scope = await chooseScope({});
  const mod = await loadUiModule();
  if (!mod) return;
  const team = { team: name, about: '', steps: [] };
  const steps = await mod.launchEditor(team);
  if (!steps) { console.log('\n  ' + C.dim('closed — nothing created.') + '\n'); return; }
  const { teamToYaml } = require('../lib/serialize');
  const file = store.saveTeam(name, teamToYaml({ ...team, steps }), { local: scope.local });
  console.log('\n  ' + C.green('✔ created ') + C.cyan(name) + C.dim('  (' + file + ')'));
  show(name);
}

async function editCmd(name, instruction, opts = {}) {
  const file = store.fileOf(name);
  if (!file) return notFound(name);
  if (!opts.headless) return pointer('edit ' + name + (instruction ? ' "' + instruction + '"' : ''));
  let y = store.loadRaw(name);
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  if (instruction) {
    try {
      const stop = startSpinner('updating…');
      y = await compose.edit(y, instruction);
      stop();
    } catch (e) { rl.close(); return composeError(e); }
  } else {
    console.log('\n  ' + C.bold('editing ') + C.cyan(name) + C.dim('  — describe changes in plain words'));
  }
  await refine(rl, y, { file });
}

// Shared refine loop: show the workflow, take a plain-language change, redraw.
async function refine(rl, y, saveTo) {
  while (true) {
    const team = preview(y);
    const ans = await ask(rl, C.cyan('  change it in words, or press enter to save: '));
    if (!ans) {
      rl.close();
      const file = saveTo.file
        ? store.saveAt(saveTo.file, y)
        : store.saveTeam(team.team, y, { local: saveTo.local });
      console.log('\n  ' + C.green('✔ saved ') + C.dim(file));
      console.log('  ' + C.dim('run it:') + '  ' + C.cyan(`mmt run ${team.team} "your task"`) + '\n');
      return;
    }
    try {
      const stop = startSpinner('updating…');
      y = await compose.edit(y, ans);
      stop();
    } catch (e) { console.log('  ' + C.red(e.message)); }
  }
}

function composeError(e) {
  console.log('\n  ' + C.red(e.message));
  console.log('  ' + C.dim('this uses the `claude` CLI to compose. make sure `claude` runs in this shell.') + '\n');
}

function help() {
  console.log(`
  ${C.bold('mmt')} ${C.dim('— compose, reuse, and run your mini teams (agent workflows)')}

  ${C.dim('grammar: ')}${C.bold('mmt <verb> <type> <name>')}${C.dim(', type ∈ team | agent | skill (run is the one exception — it only takes a team)')}

  ${C.cyan('mmt run <team> "task"')}                  run a team on your subscription (via Claude Code)
  ${C.cyan('mmt list teams|agents|skills')}           list what you have ${C.dim('(aliases: mmt teams · mmt skills · mmt agents)')}

  ${C.dim('authoring — ')}${C.bold('bare')}${C.dim(' = describe it, Claude drafts/updates it · ')}${C.bold('--ui')}${C.dim(' = edit it yourself')}
  ${C.cyan('mmt new team|agent|skill <name> [text]')}    create one
  ${C.cyan('mmt edit team|agent|skill <name> ["change"]')}    update one
  ${C.cyan('mmt show team|agent|skill <name>')}          print one
  ${C.cyan('mmt delete team|agent|skill <name>')}        delete one ${C.dim('(alias: rm)')}

  ${C.cyan('mmt export <team> [dir]')}   write a reviewable bundle: team.yaml + agents/ + skills/ ${C.dim('(--force to overwrite)')}
  ${C.cyan('mmt import <dir>')}          install a bundle after a manifest + consent ${C.dim('(--yes for non-interactive · --force)')}
  ${C.dim('· or ')}${C.cyan("mmt import '<token>'")}${C.dim(' / ')}${C.cyan('mmt import <file>')}${C.dim(' — the legacy token/yaml/file forms')}
  ${C.dim('flags: --local/--global (scope) · --model <opus|sonnet|haiku> · --sim · --headless')}
`);
}

(async function main() {
  const a = process.argv.slice(2);
  const flags = { fast: false, sim: false, local: false, global: false, help: false, headless: false, model: null, prompt: null, file: false, ui: false, force: false, yes: false };
  const args = [];
  let endFlags = false;
  for (let i = 0; i < a.length; i++) {
    const x = a[i];
    if (endFlags) { args.push(x); }
    else if (x === '--') endFlags = true;
    else if (x === '--fast') flags.fast = true;
    else if (x === '--sim') flags.sim = true;
    else if (x === '--headless') flags.headless = true;
    else if (x === '--local') flags.local = true;
    else if (x === '--global') flags.global = true;
    else if (x === '--file') flags.file = true;
    else if (x === '--ui' || x === '--editor') flags.ui = true;
    else if (x === '--force') flags.force = true;
    else if (x === '--yes' || x === '-y') flags.yes = true;
    else if (x === '--help' || x === '-h') flags.help = true;
    else if (x === '--model') flags.model = a[++i] || null;
    else if (x === '--prompt') flags.prompt = a[++i] || null;
    else if (x.startsWith('--')) { /* ignore unknown long flag */ }
    else args.push(x); // positional (incl. values beginning with a single '-')
  }
  const cmd = args[0];

  // `mmt <verb> <type> <name> [rest...]` — type MUST be team|agent|skill, else null
  // (removes the bare mmt new "<desc>" form AND every typeless show/edit/delete <team> form).
  const TYPES = ['team', 'agent', 'skill'];
  function typedArgs(a2) {
    if (!TYPES.includes(a2[1])) return null;
    return { type: a2[1], name: a2[2], rest: a2.slice(3).join(' ') };
  }
  function usageError(msg) {
    console.log('\n  ' + C.dim('usage:') + '  ' + C.cyan(msg) + '\n');
  }

  try {
    if (flags.help || cmd === 'help') help();
    else if (!cmd) help();
    else if (cmd === 'list' || cmd === 'ls') {
      if (args[1] === 'agents') agentsList();
      else if (args[1] === 'skills') skillsList();
      else home();
    }
    else if (cmd === 'teams') home();
    else if (cmd === 'skills') skillsList();
    else if (cmd === 'agents') agentsList();
    else if (cmd === 'run') await run(args[1], args.slice(2).join(' '), { fast: flags.fast, sim: flags.sim, headless: flags.headless, model: flags.model });
    else if (cmd === 'new') {
      const t = typedArgs(args);
      if (!t) return usageError('mmt new team|agent|skill <name>');
      if (!t.name) return usageError('mmt new ' + t.type + ' <name>');
      if (t.type === 'team') { if (flags.ui) await launchUiNew(t.name); else await newTeam(t.name, t.rest, { local: flags.local, headless: flags.headless, prompt: flags.prompt }); }
      else if (t.type === 'agent') { if (flags.ui) await launchAgentUiNew(t.name); else await agentCmd('new', t.name, { desc: t.rest, prompt: flags.prompt, file: flags.file, ui: flags.ui, local: flags.local, global: flags.global }); }
      else await skillCmd('new', t.name, { desc: t.rest, prompt: flags.prompt, file: flags.file, ui: flags.ui, local: flags.local, global: flags.global });
    }
    else if (cmd === 'edit') {
      const t = typedArgs(args);
      if (!t) return usageError('mmt edit team|agent|skill <name>');
      if (!t.name) return usageError('mmt edit ' + t.type + ' <name>');
      if (t.type === 'team') { if (flags.ui) await launchUi(t.name); else await editCmd(t.name, t.rest, { headless: flags.headless }); }
      else if (t.type === 'agent') { if (flags.ui) await launchAgentUi(t.name); else await agentCmd('edit', t.name, { desc: t.rest, prompt: flags.prompt, file: flags.file, ui: flags.ui, local: flags.local, global: flags.global }); }
      else await skillCmd('edit', t.name, { desc: t.rest, prompt: flags.prompt, file: flags.file, ui: flags.ui, local: flags.local, global: flags.global });   // NOT editCmd — editCmd is team-only
    }
    else if (cmd === 'show') {
      const t = typedArgs(args);
      if (!t) return usageError('mmt show team|agent|skill <name>');
      if (!t.name) return usageError('mmt show ' + t.type + ' <name>');
      if (t.type === 'team') show(t.name);
      else if (t.type === 'agent') await agentCmd('show', t.name);
      else await skillCmd('show', t.name);
    }
    else if (cmd === 'delete' || cmd === 'rm') {
      const t = typedArgs(args);
      if (!t) return usageError('mmt delete team|agent|skill <name>');
      if (!t.name) return usageError('mmt delete ' + t.type + ' <name>');
      if (t.type === 'team') delTeam(t.name);
      else if (t.type === 'agent') delAgent(t.name);
      else delSkill(t.name);
    }
    else if (cmd === 'export') exportCmd(args[1], args[2], { force: flags.force });
    else if (cmd === 'import') await importCmd(args[1], { local: flags.local, force: flags.force, yes: flags.yes });
    else usageError('mmt help  — see all commands');
  } catch (e) {
    console.error('\n  ' + C.red(e.message) + '\n');
    process.exit(1);
  }
})();
