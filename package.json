{
  "name": "@mamadoudicko/mmt",
  "version": "0.2.0",
  "description": "Compose, reuse, and run your own agent workflows (mini teams). Name them, run them on any task, watch each step.",
  "bin": {
    "mmt": "bin/mmt"
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "skills",
    ".claude/commands",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "node test/editor.test.js && node test/serialize.test.js && node test/editor-forms.test.js && node test/editor-ui.test.mjs && node test/bundle.test.js && node test/cli.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mamadoudicko/my-mini-team.git"
  },
  "homepage": "https://mamadoudicko.github.io/my-mini-team/",
  "bugs": {
    "url": "https://github.com/mamadoudicko/my-mini-team/issues"
  },
  "keywords": [
    "cli",
    "agent",
    "workflow",
    "claude",
    "claude-code",
    "team",
    "subagents"
  ],
  "license": "MIT",
  "devDependencies": {
    "ink-testing-library": "^4.0.0"
  }
}
